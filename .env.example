# ============================================================
# .env.example
# 이 파일을 복사하여 .env 로 이름을 변경한 뒤 값을 채워 넣는다.
#   cp .env.example .env      (Linux/Mac)
#   copy .env.example .env    (Windows)
# ============================================================

# ──────────────────────────────────────────────────────────────
# Step 1: Confluence 데이터 가져오기 (run_convert.py)
# ──────────────────────────────────────────────────────────────

# Confluence 인스턴스 URL (끝에 /wiki 붙이지 않음)
CONFLUENCE_URL=https://your-site.atlassian.net

# Confluence Personal Access Token
#   Cloud : https://id.atlassian.com/manage-profile/security/api-tokens
#   Server/DC : 프로필 > 개인 액세스 토큰 > 토큰 만들기
CONFLUENCE_PAT=your-personal-access-token

# 변환할 Confluence 루트 페이지 ID (쉼표로 여러 개 지정 가능)
#   예: 1427741158 또는 1427741158,1462521351
CONFLUENCE_PAGE_IDS=1427741158

# ──────────────────────────────────────────────────────────────
# Step 2: Notion DB 업로드 (run_upload.py)
# ──────────────────────────────────────────────────────────────

# Notion Integration 토큰
#   https://www.notion.so/my-integrations 에서 생성
#   생성 후 대상 DB 페이지에서 ··· > 연결 추가 로 Integration을 연결해야 함
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 업로드 대상 Notion Database ID
#   DB 페이지 URL에서 추출하거나 아래 유틸리티로 조회:
#     uv run python utils/get_bot_databases.py
NOTION_DATABASE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Notion API 설정 — 사내 프록시 서버를 경유할 경우 URL/PATH/VERSION 변경
NOTION_API_URL=https://api.notion.com
NOTION_API_PATH=v1
NOTION_API_VERSION=2022-06-28
